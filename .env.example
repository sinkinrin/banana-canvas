# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional. Local project/file storage directory. Relative paths resolve from the app root.
# BANANA_DATA_DIR="./data"

# image2 relay settings. Required when using the Image2 model.
IMAGE2_BASE_URL="YOUR_IMAGE2_BASE_URL"
IMAGE2_API_KEY="YOUR_IMAGE2_API_KEY"
IMAGE2_MODEL="YOUR_IMAGE2_MODEL"
# Optional. Auto uses images for gpt-image-* and chat for other models.
# IMAGE2_ENDPOINT_TYPE="images"
# Optional. Used by image2 after a direct network failure.
# IMAGE2_HTTPS_PROXY="http://127.0.0.1:7890"
# Optional. direct | auto | proxy. Defaults to direct.
# IMAGE2_PROXY_MODE="direct"
# Optional. Cost-safe defaults send one image request. Increase attempts only if you accept duplicate generation cost risk.
# IMAGE2_MAX_ATTEMPTS="1"
# Optional. true enables proxy/direct hedged racing when IMAGE2_MAX_ATTEMPTS > 1. This can consume extra image tokens.
# IMAGE2_HEDGE_ENABLED="false"
# Optional. direct image2 requests prefer HTTP/2 by default to better match browser clients like Cherry Studio.
# IMAGE2_DIRECT_ALLOW_H2="true"
# IMAGE2_DIRECT_CONNECT_TIMEOUT_MS="60000"
# Optional. true asks the images endpoint for SSE image events. Useful when a relay has a ~60s idle gateway timeout.
# IMAGE2_STREAM="false"
# Optional. 0-3 streamed partial images. Values above 0 can keep relay connections active but may cost extra image tokens.
# IMAGE2_PARTIAL_IMAGES="1"
# IMAGE2_REQUEST_TIMEOUT_MS="240000"
# IMAGE2_RETRY_DELAY_MS="1000"
# IMAGE2_PROXY_CONNECT_TIMEOUT_MS="60000"
# HTTPS_PROXY="http://127.0.0.1:7890"
# HTTP_PROXY="http://127.0.0.1:7890"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
